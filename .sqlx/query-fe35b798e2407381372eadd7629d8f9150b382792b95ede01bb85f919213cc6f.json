  "query": "SELECT *, COALESCE((EXTRACT(EPOCH FROM (now() - reserved_at)) / 60)::int, 0) as \"reserved_minutes!\"\n                 FROM game\n                WHERE id = $1\n                  AND location_id = $2\n                  AND deleted_at IS NULL\n                  AND disabled_at IS NULL\n                  AND reserved_at IS NULL\n             FOR UPDATE",
