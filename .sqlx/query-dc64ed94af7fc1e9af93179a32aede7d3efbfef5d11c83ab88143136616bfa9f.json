  "query": "INSERT INTO game (location_id, name, abbreviation)\n                        SELECT id, $2, $3 FROM location\n                         WHERE id = $1\n                           AND deleted_at IS NULL\n                RETURNING *, COALESCE((EXTRACT(EPOCH FROM (now() - reserved_at)) / 60)::int, 0) as \"reserved_minutes!\"",
